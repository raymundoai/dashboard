# Tiny ERP
TINY_API_TOKEN=

# SQLite DB. In Easypanel, mount a persistent volume at /app/db.
TINY_DB_PATH=/app/db/dash_final.sqlite

# Auth — 3 users max (generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'pw', bcrypt.gensalt()).decode())")
AUTH_USER_1_NAME=admin
AUTH_USER_1_HASH=
AUTH_USER_2_NAME=
AUTH_USER_2_HASH=
AUTH_USER_3_NAME=
AUTH_USER_3_HASH=

# JWT
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=change-me-in-production
AUTH_COOKIE_NAME=brew_session
AUTH_TOKEN_EXPIRE_HOURS=168
AUTH_SECURE_COOKIE=true

# Filtering
TINY_EXCLUDED_SITUACOES=cancelado,em aberto
# Incremental sync revisits the last 60 days to catch late order edits.
TINY_SYNC_LOOKBACK_DAYS=60
TINY_DETAIL_WORKERS=6
TINY_DETAIL_RETRIES=2
TINY_MIN_REQUEST_INTERVAL=0.35
TINY_API_RATE_LIMIT_RETRIES=3
TINY_API_RATE_LIMIT_SLEEP=20
TINY_SQLITE_TIMEOUT_SECONDS=30
TINY_SQLITE_BUSY_TIMEOUT_MS=30000
TINY_SQLITE_CACHE_SIZE_KB=16384
TINY_SQLITE_MMAP_SIZE_MB=64
TINY_OPEN_ORDER_ALERT_DAYS=1
TINY_EXCLUDED_REVENUE_MARKERS=racao,ração

# GA4 (for funnel)
GA4_PROPERTY_ID_BREW=
GA4_PROPERTY_ID_GROW=
# Either mount the JSON file and set GOOGLE_APPLICATION_CREDENTIALS,
# or provide the same service account JSON as base64 in GOOGLE_CREDENTIALS_B64.
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/ga4-service-account.json
GOOGLE_CREDENTIALS_B64=
GA4_SCOPES=https://www.googleapis.com/auth/analytics.readonly

# CORS. In same-origin production this can be omitted, but keep the public URL if needed.
CORS_ORIGINS=http://localhost:5173
