# Tiny ERP
TINY_API_TOKEN=

# DB (relative to backend working dir)
TINY_DB_PATH=../db/dash_final.sqlite

# Auth — 3 users max (generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'pw', bcrypt.gensalt()).decode())")
AUTH_USER_1_NAME=admin
AUTH_USER_1_HASH=

# JWT
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=change-me-in-production
AUTH_COOKIE_NAME=brew_session
AUTH_TOKEN_EXPIRE_HOURS=24
AUTH_SECURE_COOKIE=false

# Filtering
TINY_EXCLUDED_SITUACOES=cancelado,em aberto
TINY_SYNC_LOOKBACK_DAYS=7
TINY_DETAIL_WORKERS=6

# GA4 (for funnel)
GA4_PROPERTY_ID_BREW=
GA4_PROPERTY_ID_GROW=
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/ga4-service-account.json

# CORS (for dev)
CORS_ORIGINS=http://localhost:5173
